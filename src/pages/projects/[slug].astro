---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/portfolio';
import ProjectImage from '../../components/ProjectImage.astro';

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
---

<Layout title={`${project.name} - Proyecto`} description={project.description}>
  <article class="min-h-screen pt-24 pb-16">
    <div class="max-w-4xl mx-auto px-6">
      <a href="/#projects" class="inline-flex items-center gap-2 text-gray-500 hover:text-white transition mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Volver a Proyectos
      </a>

      <div class="aspect-video rounded-lg overflow-hidden mb-8 bg-white/5">
        <ProjectImage 
          image={project.image} 
          slug={project.slug}
          class="w-full h-full object-cover"
        />
      </div>
      
      <header class="mb-8">
        <h1 class="text-4xl md:text-5xl font-bold mt-2 mb-4">{project.name}</h1>
        <p class="text-xl text-gray-400">{project.description}</p>
      </header>

      <div class="prose prose-invert prose-lg max-w-none mb-12">
        <p class="text-gray-300 leading-relaxed">{project.fullDescription}</p>
      </div>

      <section class="mb-8">
        <h2 class="text-2xl font-semibold mb-4">Tecnologías</h2>
        <div class="flex flex-wrap gap-2">
          {project.tech.map((tech) => (
            <span class="px-3 py-1 bg-white/10 border border-white/20 text-gray-300 rounded-full text-sm">{tech}</span>
          ))}
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-semibold mb-4">Características</h2>
        <ul class="space-y-3">
          {project.features.map((feature) => (
            <li class="flex items-start gap-3 text-gray-400">
              <span class="text-white mt-1">→</span>
              {feature}
            </li>
          ))}
        </ul>
      </section>

      <div class="flex gap-4">
        {project.url && (
          <a href={project.url} target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-black font-medium rounded-full hover:bg-gray-200 transition">
            Ver proyecto
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        )}
        <a href={project.repo} target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-6 py-3 border border-white/20 rounded-full hover:bg-white/10 transition">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Código fuente
        </a>
      </div>
    </div>
  </article>
</Layout>
