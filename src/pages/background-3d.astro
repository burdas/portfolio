---
import Layout from '../layouts/Layout.astro';
import NoiseBackground from '../components/NoiseBackground.astro';
---

<Layout title="Background 3D - Noise Animation">
  <NoiseBackground />
  
  <section class="min-h-screen flex items-center justify-center relative">
    <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
      <h1 class="text-5xl md:text-7xl font-bold mb-6 tracking-tight text-white">
        Background 3D
      </h1>
      <p class="text-xl md:text-2xl text-gray-400 mb-8 max-w-2xl mx-auto">
        Animación de ruido procedural con Three.js
      </p>
      <a href="/" class="px-6 py-3 bg-white text-black font-medium rounded-full hover:bg-gray-200 transition">
        Volver al Portfolio
      </a>
    </div>
  </section>
</Layout>
