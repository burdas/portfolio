---
import ProjectImage from "./ProjectImage.astro";
import GlassCard from "../Shared/GlassCard.astro";

interface Project {
  slug: string;
  name: string;
  url?: string;
  repo?: string;
  description: string;
  fullDescription?: string;
  tech: string[];
  features?: string[];
  image: string;
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<a
  href={`/projects/${project.slug}`}
  class="group relative block cursor-pointer"
>
  <GlassCard
    bgClass="bg-white/[0.02]"
    showGradient={true}
    class="p-6! h-full overflow-hidden border-white/5 hover:border-indigo-500/50 hover:shadow-[0_0_30px_-10px_rgba(99,102,241,0.4)] transition-all duration-300"
  >
    <div class="aspect-video bg-white/5 relative overflow-clip rounded-lg">
      <ProjectImage
        image={project.image}
        slug={project.slug}
        class="w-full h-full rounded-lg object-cover group-hover:scale-105 transition-transform duration-500"
      />
    </div>
    <div
      class="relative z-10 pt-4 group-hover:-translate-y-1 transition-transform duration-300"
    >
      <h3
        class="text-lg font-semibold text-white mb-2 group-hover:text-indigo-300 transition flex items-center gap-2"
      >
        {project.name}
        <span
          class="text-sm text-gray-500 group-hover:text-indigo-400 group-hover:translate-x-1 transition-all duration-300"
          >↗</span
        >
      </h3>
      <p
        class="text-gray-400 text-sm mb-4 line-clamp-2 group-hover:text-gray-300 transition"
      >
        {project.description}
      </p>
      <div class="flex flex-wrap gap-1.5">
        {
          project.tech
            .slice(0, 4)
            .map((tech) => (
              <span class="px-2 py-0.5 bg-indigo-500/10 text-indigo-300 text-xs rounded group-hover:bg-indigo-500/20 group-hover:text-indigo-200 transition-all duration-300">
                {tech}
              </span>
            ))
        }
      </div>
    </div>
  </GlassCard>
</a>
