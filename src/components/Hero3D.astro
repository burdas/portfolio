---
import NoiseBackground from "./NoiseBackground.astro";
import Scene3D from "./Scene3D.astro";
import SocialButton from "./SocialButton.astro";
import { Icon } from "astro-icon/components";
---

<section
  id="hero-3d"
  class="min-h-[calc(100vh-64px)] flex items-end justify-center relative overflow-hidden"
>
  <div class="absolute inset-0 pointer-events-auto">
    <Scene3D />
  </div>
  <div class="text-center relative z-20 pointer-events-none space-y-36">
    <div class="inline-block pointer-events-auto">
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-widest mb-2">
        Marcos Burdaspar
      </h1>
      <p class="text-gray-300/50 text-xl font-thin mb-2">
        <span class="text-primary font-thin">&lt;</span> Software developer <span
          class="text-primary font-thin">/&gt;</span
        >
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <SocialButton href="https://github.com/burdas" icon="github" />
        <SocialButton href="https://linkedin.com/in/burdas" icon="linkedin" />
      </div>
    </div>
    <div class="flex flex-col place-items-center gap-1 text-gray-300/60">
      <!-- <span class="text-sm font-light tracking-widest">EXPLORAR</span> -->
      <Icon name="mouse" class="size-6" />
      <Icon name="arrow_down" class="size-6 animate-bounce" />
    </div>
  </div>
</section>
