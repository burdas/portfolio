---
import { education } from '../data/portfolio';
---

<section id="education" class="py-24 border-t border-white/5">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="text-3xl font-bold mb-12">Formación</h2>
    <div class="space-y-6">
      {education.map((edu) => (
        <div class="p-6 bg-white/5 rounded-lg border border-white/10">
          <div class="flex justify-between items-start mb-2">
            <h3 class="text-xl font-semibold text-white">{edu.degree}</h3>
            <span class="text-gray-500 text-sm">{edu.period}</span>
          </div>
          <p class="text-gray-400 mb-2">{edu.institution}</p>
          <p class="text-gray-500">{edu.details}</p>
        </div>
      ))}
    </div>
  </div>
</section>
