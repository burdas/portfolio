---
import GlassCard from "../Shared/GlassCard.astro";
import Experience from "./Experience.astro";
import Education from "./Education.astro";
---

<section id="career" class="py-24 relative">
  <div class="max-w-6xl mx-auto px-6">
    <GlassCard>
      <div class="flex items-center gap-4 mb-12">
        <div class="w-12 h-0.5 bg-linear-to-r from-indigo-500 to-transparent">
        </div>
        <h2 class="text-3xl font-bold">Trayectoria</h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-12">
        <div>
          <Experience />
        </div>

        <div>
          <Education />
        </div>
      </div>
    </GlassCard>
  </div>
</section>
