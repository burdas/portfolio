---
import { experience } from "../../data/portfolio";
---

<h3 class="text-xl font-semibold text-gray-200 mb-8 flex items-center gap-2">
  <span class="w-2 h-2 bg-indigo-500 rounded-full"></span>
  Experience
</h3>
<div class="space-y-8">
  {
    experience.map((job) => (
      <a href={`/experience/${job.slug}`} class="block group">
        <article class="relative pl-6 transition-all job-timeline">
          <div class="absolute left-0 top-0 bottom-0 flex flex-col gap-1 items-center">
            <div class="w-2 h-2 bg-gray-500 rounded-full overflow-clip flex flex-col items-start">
              <div class="fill-dot w-full bg-primary" />
            </div>
            <div class="h-full w-0.5 rounded-full bg-gray-500">
              <div class="fill-bar h-0 w-full bg-primary" />
            </div>
          </div>
          <div class="mb-1">
            <span class="text-xs text-gray-500">{job.period}</span>
          </div>
          <h4 class="text-lg font-semibold text-white group-hover:text-indigo-300 transition">
            {job.role}
          </h4>
          <p class="text-gray-400 text-sm mb-2">{job.company}</p>
          <p class="text-gray-500 text-sm line-clamp-2">{job.description}</p>
          <div class="mt-2 text-xs text-gray-500 flex items-center gap-1 group-hover:text-indigo-400 transition">
            Ver más <span class="group-hover:translate-x-1 transition">→</span>
          </div>
        </article>
      </a>
    ))
  }
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  document.addEventListener("astro:page-load", () => {
    gsap.registerPlugin(ScrollTrigger);

    const timelines = document.querySelectorAll(".job-timeline");

    timelines.forEach((timeline) => {
      const fillBar = timeline.querySelector(".fill-bar");
      const fillDot = timeline.querySelector(".fill-dot");

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: timeline,
          start: "top 50%",
          end: "bottom 50%",
          scrub: true,
        },
      });

      tl.fromTo(
        fillDot,
        { height: "0%" },
        { height: "100%", duration: 1 },
      ).fromTo(fillBar, { height: "0%" }, { height: "100%", duration: 1 });
    });
  });
</script>
