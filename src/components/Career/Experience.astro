---
import { experience } from "../../data/portfolio";
---

<h3 class="text-xl font-semibold text-gray-200 mb-8 flex items-center gap-2">
  <span class="w-2 h-2 bg-indigo-500 rounded-full"></span>
  Experience
</h3>
<div class="space-y-8">
  {
    experience.map((job) => (
      <a href={`/experience/${job.slug}`} class="block group">
        <article class="relative pl-6 transition-all">
          <div class="absolute left-0 top-0 bottom-0 flex flex-col gap-1 items-center">
            <div class="w-3 h-3 bg-indigo-500/30 rounded-full" />
            <div class="h-full w-0.5 rounded-full bg-gray-400/50">
              <div class="h-3/5 w-full bg-primary" />
            </div>
          </div>
          <div class="mb-1">
            <span class="text-xs text-gray-500">{job.period}</span>
          </div>
          <h4 class="text-lg font-semibold text-white group-hover:text-indigo-300 transition">
            {job.role}
          </h4>
          <p class="text-gray-400 text-sm mb-2">{job.company}</p>
          <p class="text-gray-500 text-sm line-clamp-2">{job.description}</p>
          <div class="mt-2 text-xs text-gray-500 flex items-center gap-1 group-hover:text-indigo-400 transition">
            Ver más <span class="group-hover:translate-x-1 transition">→</span>
          </div>
        </article>
      </a>
    ))
  }
</div>
