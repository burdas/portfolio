---
interface Props {
  class?: string;
  bgClass?: string;
  showGradient?: boolean;
  shadowClass?: string;
}

const { 
  class: className = "", 
  bgClass = "bg-white/[0.03]", 
  showGradient = true,
  shadowClass = "shadow-[0_0_40px_-10px_rgba(99,102,241,0.3)]"
} = Astro.props;
---

<div
  class:list={[
    "relative p-8 md:p-12 rounded-2xl backdrop-blur-xl border border-white/10",
    bgClass,
    shadowClass,
    className,
  ]}
>
  {showGradient && (
    <div
      class="absolute inset-0 rounded-2xl bg-linear-to-br from-indigo-500/5 via-transparent to-purple-500/5 pointer-events-none"
    >
    </div>
  )}
  <div class="relative z-10">
    <slot />
  </div>
</div>
