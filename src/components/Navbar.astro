---
const navLinks = [
  { href: "/#about", label: "Sobre mí" },
  { href: "/#experience", label: "Experiencia" },
  { href: "/#projects", label: "Proyectos" },
  { href: "/#contact", label: "Contacto" }
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-black/80 backdrop-blur-md border-b border-white/10">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
    <a href="/" class="text-lg font-medium hover:text-gray-300 transition">
      Marcos Burdaspar
    </a>
    <ul class="flex gap-8 text-sm text-gray-400">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="hover:text-white transition">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
