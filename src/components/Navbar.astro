---
import NavbarDesktop from "./NavbarDesktop.astro";
import NavbarMobile from "./NavbarMobile.astro";

const navLinks = [
  { href: "/#about", label: "Sobre mí" },
  { href: "/#career", label: "Trayectoria" },
  { href: "/#projects", label: "Proyectos" },
  { href: "/#contact", label: "Contacto" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 flex justify-center py-2">
  <NavbarDesktop navLinks={navLinks} />
  <NavbarMobile navLinks={navLinks} />
</header>
