---
import { experience, education } from "../data/portfolio";
import GlassCard from "./GlassCard.astro";
---

<section id="career" class="py-24 relative">
  <div class="max-w-6xl mx-auto px-6">
    <GlassCard>
      <div class="flex items-center gap-4 mb-12">
          <div
            class="w-12 h-0.5 bg-gradient-to-r from-indigo-500 to-transparent"
          >
          </div>
          <h2 class="text-3xl font-bold">Trayectoria</h2>
        </div>

        <div class="grid lg:grid-cols-2 gap-12">
          <div>
            <h3
              class="text-xl font-semibold text-gray-200 mb-8 flex items-center gap-2"
            >
              <span class="w-2 h-2 bg-indigo-500 rounded-full"></span>
              Experiencia
            </h3>
            <div class="space-y-8">
              {
                experience.map((job) => (
                  <a href={`/experience/${job.slug}`} class="block group">
                    <article class="relative pl-6 border-l border-white/10 hover:border-indigo-500/50 transition">
                      <div class="absolute -left-1.5 top-0 w-3 h-3 bg-indigo-500/30 rounded-full group-hover:bg-indigo-500/60 transition" />
                      <div class="mb-1">
                        <span class="text-xs text-gray-500">{job.period}</span>
                      </div>
                      <h4 class="text-lg font-semibold text-white group-hover:text-indigo-300 transition">
                        {job.role}
                      </h4>
                      <p class="text-gray-400 text-sm mb-2">{job.company}</p>
                      <p class="text-gray-500 text-sm line-clamp-2">
                        {job.description}
                      </p>
                      <div class="mt-2 text-xs text-gray-500 flex items-center gap-1 group-hover:text-indigo-400 transition">
                        Ver más{" "}
                        <span class="group-hover:translate-x-1 transition">
                          →
                        </span>
                      </div>
                    </article>
                  </a>
                ))
              }
            </div>
          </div>

          <div>
            <h3
              class="text-xl font-semibold text-gray-200 mb-8 flex items-center gap-2"
            >
              <span class="w-2 h-2 bg-purple-500 rounded-full"></span>
              Formación
            </h3>
            <div class="space-y-4">
              {
                education.map((edu) => (
                  <div class="p-5 bg-white/[0.02] rounded-xl border border-white/5 hover:border-purple-500/30 transition">
                    <div class="flex justify-between items-start mb-1">
                      <h4 class="text-lg font-semibold text-white">
                        {edu.degree}
                      </h4>
                      <span class="text-gray-500 text-xs">{edu.period}</span>
                    </div>
                    <p class="text-gray-300 text-sm mb-1">{edu.institution}</p>
                    <p class="text-gray-500 text-sm">{edu.details}</p>
                  </div>
                ))
              }
            </div>
        </div>
      </div>
    </GlassCard>
  </div>
</section>
