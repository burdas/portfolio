---
import { projects } from '../data/portfolio';
---

<section id="projects" class="py-24 border-t border-white/5">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-3xl font-bold mb-12">Proyectos Personales</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <a href={`/projects/${project.slug}`} class="group block bg-white/5 rounded-lg border border-white/10 overflow-hidden hover:border-white/30 transition">
          <div class="aspect-video bg-white/5 relative overflow-hidden">
            <img 
              src={project.image} 
              alt={project.name}
              class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
              transition:name={`project-image-${project.slug}`}
            />
            <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition flex items-center justify-center">
              <span class="text-white text-sm font-medium">Ver proyecto →</span>
            </div>
          </div>
          <div class="p-5">
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-gray-200 transition">
              {project.name}
            </h3>
            <p class="text-gray-500 text-sm mb-4 line-clamp-2">{project.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {project.tech.slice(0, 4).map((tech) => (
                <span class="px-2 py-0.5 bg-white/5 text-gray-400 text-xs rounded">{tech}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
