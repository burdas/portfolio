---
import { projects } from "../data/portfolio";
---

<section id="projects" class="py-24">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-center gap-4 mb-12">
      <div class="w-12 h-0.5 bg-gradient-to-r from-indigo-500 to-transparent"></div>
      <h2 class="text-3xl font-bold">Proyectos Personales</h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <a
          href={`/projects/${project.slug}`}
          class="group block bg-white/[0.03] backdrop-blur-sm rounded-xl border border-white/10 overflow-hidden hover:border-indigo-500/40 hover:shadow-[0_0_30px_-10px_rgba(99,102,241,0.3)] transition"
        >
          <div class="aspect-video bg-white/5 relative overflow-hidden">
            <img
              src={project.image}
              alt={project.name}
              class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
              transition:name={`project-image-${project.slug}`}
            />
            <div class="absolute inset-0 bg-indigo-500/20 opacity-0 group-hover:opacity-100 transition flex items-center justify-center">
              <span class="text-white text-sm font-medium">Ver proyecto →</span>
            </div>
          </div>
          <div class="p-5">
            <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-indigo-300 transition">
              {project.name}
            </h3>
            <p class="text-gray-400 text-sm mb-4 line-clamp-2">
              {project.description}
            </p>
            <div class="flex flex-wrap gap-1.5">
              {project.tech.slice(0, 4).map((tech) => (
                <span class="px-2 py-0.5 bg-indigo-500/10 text-indigo-300 text-xs rounded">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
