---
import { projects } from "../data/portfolio";
import ProjectImage from "./ProjectImage.astro";
---

<section id="projects" class="py-32 relative overflow-hidden">
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,var(--tw-gradient-stops))] from-indigo-500/10 via-transparent to-transparent pointer-events-none"
  >
  </div>
  <div
    class="absolute top-0 right-0 w-96 h-96 bg-indigo-500/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none"
  >
  </div>

  <div class="max-w-6xl mx-auto px-6 md:px-12 relative z-10">
    <div class="flex items-center gap-4 mb-12">
      <div class="w-12 h-0.5 bg-linear-to-r from-indigo-500 to-transparent">
      </div>
      <h2 class="text-3xl font-bold">Proyectos Personales</h2>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        projects.map((project) => (
          <a
            href={`/projects/${project.slug}`}
            class="group relative block bg-white/2 backdrop-blur-sm rounded-2xl border border-white/5 overflow-hidden hover:border-indigo-500/50 hover:shadow-[0_0_30px_-10px_rgba(99,102,241,0.4)] transition-all duration-300 cursor-pointer"
          >
            <div class="absolute inset-0 rounded-2xl bg-linear-to-br from-indigo-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none">
            </div>
            <div class="aspect-video bg-white/5 relative overflow-hidden">
              <ProjectImage 
                image={project.image} 
                slug={project.slug} 
                class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
              />
            </div>
            <div class="relative z-10 p-5 group-hover:-translate-y-1 transition-transform duration-300">
              <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-indigo-300 transition flex items-center gap-2">
                {project.name}
                <span class="text-sm text-gray-500 group-hover:text-indigo-400 group-hover:translate-x-1 transition-all duration-300">↗</span>
              </h3>
              <p class="text-gray-400 text-sm mb-4 line-clamp-2 group-hover:text-gray-300 transition">
                {project.description}
              </p>
              <div class="flex flex-wrap gap-1.5">
                {project.tech.slice(0, 4).map((tech) => (
                  <span class="px-2 py-0.5 bg-indigo-500/10 text-indigo-300 text-xs rounded group-hover:bg-indigo-500/20 group-hover:text-indigo-200 transition-all duration-300">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
