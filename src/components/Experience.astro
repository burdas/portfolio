---
import { experience } from '../data/portfolio';
---

<section id="experience" class="py-24 border-t border-white/5">
  <div class="max-w-4xl mx-auto px-6">
    <h2 class="text-3xl font-bold mb-12">Experiencia Laboral</h2>
    <div class="space-y-12">
      {experience.map((job) => (
        <a href={`/experience/${job.slug}`} class="block group">
          <article class="relative pl-8 border-l border-white/10 hover:border-white/30 transition">
            <div class="absolute -left-1.5 top-0 w-3 h-3 bg-white/20 rounded-full group-hover:bg-white/40 transition"></div>
            <div class="mb-2">
              <span class="text-sm text-gray-500">{job.period}</span>
            </div>
            <h3 class="text-xl font-semibold text-white group-hover:text-gray-200 transition">
              {job.role}
            </h3>
            <p class="text-gray-400 mb-2">{job.company}</p>
            <p class="text-gray-500 mb-4 line-clamp-2">{job.description}</p>
            <ul class="space-y-2">
              {job.highlights.slice(0, 3).map((highlight) => (
                <li class="flex items-start gap-2 text-gray-500 text-sm">
                  <span class="text-gray-400 mt-0.5">→</span>
                  {highlight}
                </li>
              ))}
            </ul>
            <div class="mt-4 text-sm text-gray-500 flex items-center gap-1 group-hover:text-white transition">
              Ver más <span class="group-hover:translate-x-1 transition">→</span>
            </div>
          </article>
        </a>
      ))}
    </div>
  </div>
</section>
