---
import NoiseBackground from "../Shared/NoiseBackground.astro";
import Scene3D from "./Scene3D.astro";
import SocialButton from "../Shared/SocialButton.astro";
import { Icon } from "astro-icon/components";

const name = "Marcos Burdaspar";
---

<section
  id="hero-3d"
  class="min-h-dvh flex items-end justify-center relative overflow-hidden"
>
  <NoiseBackground />
  <div class="absolute inset-0 pointer-events-none md:pointer-events-auto">
    <Scene3D />
  </div>
  <div class="text-center relative z-20 pointer-events-none space-y-36">
    <div class="inline-block pointer-events-auto">
      <h1
        class="text-5xl md:text-8xl font-extrabold tracking-widest mb-2 font-['Geist_Variable'] glitch-wrapper"
        id="hero-title"
      >
        {
          name.split("").map((char, i) => (
            <span class="char" data-index={i}>
              {char === " " ? "\u00A0" : char}
            </span>
          ))
        }
      </h1>
      <p class="text-gray-300/50 text-xl font-thin mb-2" id="hero-subtitle">
        <span class="text-primary">&lt;</span> Software developer <span
          class="text-primary">/&gt;</span
        >
      </p>
      <div class="flex gap-4 justify-center flex-wrap" id="social-buttons">
        <SocialButton href="https://github.com/burdas" icon="github" />
        <SocialButton href="https://linkedin.com/in/burdas" icon="linkedin" />
      </div>
    </div>
    <div class="flex flex-col place-items-center gap-1 text-gray-300/60">
      <Icon name="mouse" class="size-6" />
      <Icon name="arrow_down" class="size-6 animate-bounce" />
    </div>
  </div>
  <div
    class="absolute bottom-0 left-0 right-0 h-32 bg-linear-to-t from-black to-transparent pointer-events-none"
  >
  </div>

  <script>
    import { gsap } from "gsap";

    const chars =
      "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()_+-=[]{}|;:,.<>?";
    const primaryColor = "#6366f1";
    const secondaryColors = [
      "#6366f1",
      "#818cf8",
      "#4f46e5",
      "#8b5cf6",
      "#a78bfa",
    ];

    function getRandomChar() {
      return chars[Math.floor(Math.random() * chars.length)];
    }

    function getRandomPrimaryColor() {
      return secondaryColors[
        Math.floor(Math.random() * secondaryColors.length)
      ];
    }

    document.addEventListener("astro:page-load", () => {
      const titleChars = document.querySelectorAll("#hero-title .char");
      const subtitle = document.querySelector("#hero-subtitle");
      const socialButtons = document.querySelectorAll("#social-buttons > *");

      const originalText = Array.from(titleChars).map((el) => el.textContent);

      titleChars.forEach((el) => {
        el.textContent = getRandomChar();
      });

      const tl = gsap.timeline({ defaults: { ease: "power1.out" } });

      titleChars.forEach((el, i) => {
        const finalChar = originalText[i];

        tl.to(
          el,
          {
            opacity: 1,
            duration: 0.01,
          },
          i * 0.1,
        ).call(
          () => {
            let iterations = 0;
            const maxIterations = 6;
            const interval = setInterval(() => {
              const element = el as HTMLElement;
              element.textContent = getRandomChar();
              element.style.color = getRandomPrimaryColor();
              iterations++;
              if (iterations >= maxIterations) {
                clearInterval(interval);
                element.textContent = finalChar;
                element.style.color = primaryColor;
                gsap.to(el, {
                  textShadow: `0 0 20px ${primaryColor}, 0 0 40px ${primaryColor}, 0 0 60px ${primaryColor}`,
                  duration: 0.15,
                  onComplete: () => {
                    gsap.to(el, {
                      color: "#ffffff",
                      textShadow: "0 0 0px transparent",
                      duration: 0.5,
                    });
                  },
                });
              }
            }, 80);
          },
          [],
          i * 0.1 + 0.01,
        );
      });

      tl.to({}, { duration: titleChars.length * 0.1 });

      tl.fromTo(
        subtitle,
        { opacity: 0, y: 20 },
        {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: "power2.out",
        },
        "-=0.3",
      )
        .fromTo(
          subtitle,
          {
            textShadow: "0 0 20px rgba(99, 102, 241, 0)",
          },
          {
            textShadow: "0 0 30px rgba(99, 102, 241, 0.5)",
            duration: 0.8,
            ease: "power2.inOut",
            yoyo: true,
            repeat: 1,
          },
          "<",
        )
        .fromTo(
          socialButtons,
          {
            opacity: 0,
            y: 30,
            scale: 0.8,
          },
          {
            opacity: 1,
            y: 0,
            scale: 1,
            duration: 0.6,
            stagger: 0.15,
            ease: "back.out(1.7)",
          },
          "-=0.6",
        );
    });
  </script>

  <style>
    #hero-title .char {
      display: inline-block;
      color: #ffffff;
      transition:
        color 0.3s ease,
        text-shadow 0.3s ease;
    }
  </style>
</section>
