---
import { Icon } from "astro-icon/components";

const techStack = [
  "PHP",
  "MySQL",
  "JavaScript",
  "TypeScript",
  "React",
  "Astro",
  "Node.js",
  "HTML5",
  "CSS",
  "Tailwind CSS",
  "Bootstrap",
  "Git",
  "GitHub",
  "Docker",
  "Dotnet",
  "Microsoft SQL Server",
  "Grafana",
  "Solidity",
  "Android Studio",
  "Qlik",
];

const getSlug = (name: string) =>
  name.toLowerCase().replace(/\s+/g, "").replace(".", "dot");
---

<section id="about" class="py-32 relative overflow-hidden">
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-indigo-500/10 via-transparent to-transparent pointer-events-none"
  >
  </div>

  <div
    class="absolute top-0 right-0 w-96 h-96 bg-indigo-500/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 pointer-events-none"
  >
  </div>

  <div class="max-w-5xl mx-auto px-6 md:px-12 relative z-10">
    <div class="flex flex-col md:flex-row gap-12 items-start">
      <div class="flex-shrink-0">
        <div class="relative group">
          <div
            class="absolute -inset-1 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-full blur opacity-30 group-hover:opacity-60 transition duration-500"
          >
          </div>
          <img
            src="https://ui-avatars.com/api/?name=Marcos+Burdaspar&background=6366f1&color=fff&size=150&font-size=0.4&bold=true"
            alt="Marcos Burdaspar"
            class="relative w-36 h-36 md:w-44 md:h-44 rounded-full border-4 border-white/10 object-cover group-hover:scale-105 transition-transform duration-500"
          />
        </div>
      </div>

      <div class="flex-1">
        <div class="mb-8">
          <h2 class="text-4xl md:text-5xl font-bold mb-4">Sobre mí</h2>
          <p class="text-xl text-gray-400 font-light leading-relaxed">
            Construyo software robusto y sistemas que transforman datos en
            decisiones.
          </p>
        </div>

        <div class="space-y-6 text-gray-300 leading-relaxed">
          <p class="text-lg">
            Ingeniero informático especializado en desarrollo full stack y
            analítica de datos, con más de 5 años de experiencia profesional
            trabajando en entornos reales de negocio y proyectos de producción.
          </p>
          <p class="text-lg">
            Actualmente trabajo como Software Engineer en consultoría,
            participando en el desarrollo de soluciones backend robustas (PHP,
            MySQL) bajo arquitecturas limpias y hexagonales, aplicando
            principios de Clean Code, Bounded Contexts, testing y Extreme
            programming.
          </p>
          <p class="text-lg">
            Mi trayectoria previa como responsable de analítica de datos me
            aporta una visión diferencial: entiendo profundamente el dato, el
            impacto del software en negocio y la importancia de tomar decisiones
            basadas en información fiable.
          </p>
        </div>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mt-16">
      <div
        class="group relative p-6 bg-white/[0.02] rounded-2xl border border-white/5 hover:border-indigo-500/50 transition-all duration-300 hover:shadow-[0_0_30px_-10px_rgba(99,102,241,0.4)]"
      >
        <div
          class="absolute inset-0 rounded-2xl bg-gradient-to-br from-indigo-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
        >
        </div>
        <div class="relative z-10">
          <div class="flex items-center gap-4 mb-4">
            <div
              class="p-3 bg-indigo-500/20 rounded-xl group-hover:bg-indigo-500/30 transition"
            >
              <Icon name="code" class="w-8 h-8 text-indigo-400" />
            </div>
            <h4 class="text-xl font-semibold text-white">
              Software Engineering
            </h4>
          </div>
          <p class="text-gray-400">
            Desarrollo backend, arquitecturas limpias, APIs y DevOps. Passion
            por el código limpio y mantenible.
          </p>
        </div>
      </div>
      <div
        class="group relative p-6 bg-white/[0.02] rounded-2xl border border-white/5 hover:border-purple-500/50 transition-all duration-300 hover:shadow-[0_0_30px_-10px_rgba(168,85,247,0.4)]"
      >
        <div
          class="absolute inset-0 rounded-2xl bg-gradient-to-br from-purple-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"
        >
        </div>
        <div class="relative z-10">
          <div class="flex items-center gap-4 mb-4">
            <div
              class="p-3 bg-purple-500/20 rounded-xl group-hover:bg-purple-500/30 transition"
            >
              <Icon name="chart" class="w-8 h-8 text-purple-400" />
            </div>
            <h4 class="text-xl font-semibold text-white">Data Analytics</h4>
          </div>
          <p class="text-gray-400">
            Análisis de datos, visualización y decisiones basadas en información
            fiable.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-16">
      <h3 class="text-2xl font-semibold mb-8 text-gray-100">
        Stack tecnológico
      </h3>
      <div class="relative overflow-hidden py-4">
        <div
          class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-black to-transparent z-10"
        >
        </div>
        <div
          class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-black to-transparent z-10"
        >
        </div>
        <div class="flex animate-marquee items-center">
          {
            [...techStack, ...techStack].map((tech) => (
              <div class="flex flex-col items-center gap-2 px-6 shrink-0 group">
                <img
                  src={`https://cdn.simpleicons.org/${getSlug(tech)}`}
                  alt={tech}
                  class="w-10 h-10 opacity-60 group-hover:opacity-100 group-hover:scale-125 transition-all duration-200"
                />
                <span class="text-xs text-gray-500 group-hover:text-gray-300 transition">
                  {tech}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .animate-marquee {
    animation: marquee 30s linear infinite;
  }

  .animate-marquee:hover {
    animation-play-state: paused;
  }
</style>
